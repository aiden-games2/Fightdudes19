const PIXEL_SIZE = 3;
const PS = PIXEL_SIZE;

const CHARS = PIXEL_CHARS.map((pc, charIdx) => ({
  ...pc,
  color: ['#e02020','#3bbed9','#06402B','#e02020','#ffe033','#ff69b4','#638756','#1a237e','#c75aff'][charIdx] || '#fff',
  draw(ctx, x, y, dir, state, headless) {
    const t = Date.now();
    const ps = (pc.name === 'SCRIBBLES') ? 1 : PIXEL_SIZE;
   const isTulip = pc.attackType === 'tulip';
    const isGoob = pc.attackType === 'goob';
    const isOgre = pc.attackType === 'ogre';
    const isScribbles = pc.name === 'SCRIBBLES';
    const cols = isTulip ? 18 : isGoob ? 12 : (isOgre && state === 'slash') ? 26 : isOgre ? 22 : isScribbles ? 31 : 14;
    const rows = isTulip ? 24 : isGoob ? 19 : isOgre ? 22 : isScribbles ? 32 : 18;
    const scribScale = isScribbles ? 1.45 : 1;
    const scribblesCenterOffset = 0;
    const totalW = cols * ps;
    const totalH = rows * ps;
    const bob = state === 'walk' ? Math.sin(t / 80) * 1.5 : 0;
   const activeGrid = (state === 'slash' && pc.slashGrid) ? pc.slashGrid : (state === 'grapple' && pc.grappleGrid) ? pc.grappleGrid : (state === 'punch' && pc.punchGrid) ? pc.punchGrid : (state === 'shoot' && pc.shootGrid) ? pc.shootGrid : (state === 'jump' && pc.jumpGrid) ? pc.jumpGrid : pc.grid;

    const off = document.createElement('canvas');
    off.width = totalW;
    off.height = totalH;
    const octx = off.getContext('2d');
    octx.imageSmoothingEnabled = false;

    for(let row = 0; row < rows; row++) {
      if(headless && row < 8) continue;
      const rowData = activeGrid[row];
      if(!rowData) continue;
      for(let col = 0; col < cols; col++) {
        const val = rowData[col];
        if(val === 0) continue;
        const cl = PIXEL_COLORS[val];
        if(!cl) continue;
        octx.fillStyle = cl;
        octx.fillRect(col * ps, row * ps, ps, ps);
      }
    }



    if(state === 'walk' && !isScribbles) {
      const legShift = Math.round(Math.sin(t / 80) * 1.5);
      const legStartRow = isTulip ? 23 : isGoob ? 18 : isOgre ? 20 : 14;
      octx.clearRect(0, legStartRow * ps, totalW, (rows - legStartRow) * ps);
      for(let row = legStartRow; row < rows; row++) {
        const rowData = activeGrid[row];
        if(!rowData) continue;
        for(let col = 0; col < cols; col++) {
          const val = rowData[col];
          if(val === 0) continue;
          const cl = PIXEL_COLORS[val];
          if(!cl) continue;
          octx.fillStyle = cl;
          const side = col < cols/2 ? -1 : 1;
          const cx = col * ps + side * legShift;
          octx.fillRect(cx, row * ps, ps, ps);
        }
      }
    }

    ctx.save();
    ctx.translate(Math.round(x), Math.round(y - totalH + ps + bob));
    if(dir < 0) {
      ctx.scale(-1, 1);
      ctx.drawImage(off, -totalW / 2, 0);
    } else {
      ctx.drawImage(off, -totalW / 2, 0);
    }
    ctx.restore();
  }
}));

