<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title> FIGHT DUDES</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #1a1a2e; font-family: 'Courier New', monospace; overflow: hidden; }
  canvas { display: block; margin: 0 auto; background: #0f0f23; }
  #ui { position: fixed; top: 0; left: 0; width: 100%; padding: 8px 20px; display: flex; justify-content: space-between; align-items: center; color: #fff; font-size: 13px; pointer-events: none; }
 .p-hud { background: linear-gradient(135deg,rgba(10,10,30,0.92),rgba(0,0,0,0.85)); border: 2px solid; padding: 6px 14px; border-radius: 2px; min-width: 120px; box-shadow: inset 0 0 10px rgba(0,0,0,0.5), 0 2px 8px rgba(0,0,0,0.8); }
   #title-screen { position: fixed; inset: 0; background: #04040e; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding-top: 32px; overflow-y: auto; color: #fff; z-index: 10; }
  .select-panel { background: rgba(0,0,0,0.6); border: 3px solid #555; padding: 10px 14px 8px; margin-bottom: 10px; width: 680px; }
  .select-panel-title { font-size: 11px; color: #888; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 10px; }
  .char-grid { display: grid; grid-template-columns: repeat(8, 72px); gap: 6px; }
  .char-card { border: 4px solid #555; background: linear-gradient(180deg,#2a2a4a 0%,#0d0d1e 60%,#050510 100%); cursor: pointer; transition: all 0.08s; text-align: center; width: 72px; height: 80px; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; }
  .char-card:hover { border-color: #aaa; background: #2a2a4a; }
  .char-card.selected-p1 { border-color: #4fc3f7; box-shadow: 0 0 10px #4fc3f7; }
  .char-card.selected-p2 { border-color: #ef5350; box-shadow: 0 0 10px #ef5350; }
  .char-card.selected-p1.selected-p2 { border-color: #ffe600; box-shadow: 0 0 10px #ffe600; }
  .char-card.selected-p3 { border-color: #ffe600; box-shadow: 0 0 10px #ffe600; }
  .char-card.locked { cursor: default; opacity: 0.4; }
  .char-card canvas { display: block; margin: 0 auto 3px; }
  .char-card .name { font-size: 8px; font-weight: bold; color: #ddd; letter-spacing: 1px; }
  .char-card .locked-icon { font-size: 20px; color: #555; }
  .p1-badge { position: absolute; top: 2px; left: 3px; font-size: 8px; color: #4fc3f7; font-weight: bold; }
  .p2-badge { position: absolute; top: 2px; right: 3px; font-size: 8px; color: #ef5350; font-weight: bold; }
  .preview-row { display: flex; gap: 20px; align-items: flex-start; margin-bottom: 14px; width: 720px; }
  .preview-box { background: rgba(0,0,0,0.5); border: 2px solid #444; padding: 10px 14px; flex: 1; min-height: 80px; }
  .preview-box .pname { font-size: 11px; letter-spacing: 2px; margin-bottom: 6px; }
  .preview-box .cname { font-size: 18px; font-weight: bold; margin-bottom: 2px; }
  .preview-box .cdesc { font-size: 10px; color: #aaa; }
  .preview-box .controls-mini { font-size: 9px; color: #555; margin-top: 6px; }
  .controls-info { font-size: 10px; color: #555; margin-bottom: 10px; }
 .map-card { border: 3px solid #444; background: #1a1a3a; cursor: pointer; padding: 8px; text-align:center; transition: all 0.08s; flex-shrink: 0; }
  .map-card:hover { border-color: #aaa; }
  .map-card.selected-map { border-color: #ffe600; box-shadow: 0 0 10px #ffe600; }
 button#startbtn { background: #0a0a14; color: #ffe600; border: 3px solid #ffe600; padding: 14px 52px; font-family: 'Courier New', monospace; font-size: 17px; font-weight: bold; cursor: pointer; letter-spacing: 5px; margin-top: 4px; transition: all 0.1s; }
  button#startbtn:hover { background: #ffe600; color: #000; }
  #gameover { position: fixed; inset: 0; background: rgba(0,0,0,0.8); display: none; flex-direction: column; align-items: center; justify-content: center; color: #fff; z-index: 10; }
#gameover h2 { font-size: 48px; color: #ffe600; margin-bottom: 10px; text-shadow: 0 0 30px #ffe600, 4px 4px 0 #7a4400; animation: vspulse 1s infinite alternate; }
  #gameover button { background: #ffe600; color: #000; border: none; padding: 12px 36px; font-family: 'Courier New', monospace; font-size: 16px; cursor: pointer; margin: 5px; font-weight: bold; letter-spacing: 3px; }
  #gameover button:hover { background: #fff; }
  #gameover-chars { display: flex; gap: 30px; align-items: flex-end; justify-content: center; margin: 10px 0 18px; }
  #trophy-text { font-size: 72px; margin-bottom: 0; animation: vspulse 0.8s infinite alternate; }
  @keyframes flamedance {
    0%   { text-shadow: 0 0 8px #ffe600, 0 -4px 16px #ff4400, 2px -8px 20px #ff8800; }
    25%  { text-shadow: -2px 0 10px #ffe600, 1px -6px 18px #ff2200, -1px -10px 22px #ff6600; }
    50%  { text-shadow: 0 0 12px #ffffff, 0 -8px 22px #ff4400, 3px -12px 28px #ffaa00; }
    75%  { text-shadow: 2px 0 8px #ffe600, -1px -5px 16px #ff3300, 1px -9px 20px #ff7700; }
    100% { text-shadow: 0 0 8px #ffe600, 0 -4px 16px #ff4400, -2px -8px 20px #ff8800; }
  }
  @keyframes flamebutton {
    0%   { box-shadow: 0 0 8px #ff4400, 0 4px 20px #ff2200, inset 0 0 8px rgba(255,100,0,0.2); background: linear-gradient(180deg,#5a2200,#1a0800); }
    50%  { box-shadow: 0 0 18px #ff6600, 0 6px 35px #ff4400, inset 0 0 14px rgba(255,150,0,0.35); background: linear-gradient(180deg,#7a3300,#2a1000); }
    100% { box-shadow: 0 0 8px #ff4400, 0 4px 20px #ff2200, inset 0 0 8px rgba(255,100,0,0.2); background: linear-gradient(180deg,#5a2200,#1a0800); }
  }
  #startbtn:hover {
    animation: flamebutton 0.4s infinite alternate !important;
    color: #ffffff !important;
    border-color: #ff6600 !important;
    animation: flamedance 0.3s infinite, flamebutton 0.4s infinite alternate !important;
  }
  #lockbtn:hover {
    background: linear-gradient(180deg,#4a3300,#1a1200) !important;
    color: #ffffff !important;
    border-color: #ffaa00 !important;
    box-shadow: 0 0 14px #ff8800 !important;
  }
  @keyframes vspulse {
    from { text-shadow: 0 0 12px #ffe600, 0 0 30px #ff8800; transform: scale(1); }
    to   { text-shadow: 0 0 28px #ffe600, 0 0 60px #ff4400; transform: scale(1.12); }
  }
  @keyframes cardglow {
    from { box-shadow: 0 0 8px rgba(255,230,0,0.2); }
    to   { box-shadow: 0 0 22px rgba(255,230,0,0.7); }
  }
  .char-card:hover { border-color: #ffe600 !important; background: linear-gradient(180deg,#3a3a00 0%,#1a1a00 60%,#050500 100%) !important; transform: scale(1.07); transition: transform 0.08s; }
  .select-panel, .preview-box { box-shadow: inset 0 0 30px rgba(255,180,0,0.04), 0 0 12px rgba(0,0,0,0.6); }
  .preview-box { border-color: #333 !important; background: linear-gradient(160deg, rgba(20,10,40,0.9), rgba(5,5,20,0.95)) !important; }

</style>
</head>
<body>
  <audio id="bgm" src="menu_music.mp3" loop></audio>
<div id="title-screen">
  <canvas id="title-bg" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0"></canvas>

  <!-- SCREEN 1: CHARACTER SELECT -->
  <div id="screen-chars" style="position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;width:100%;height:100vh;padding:18px 0 10px;box-sizing:border-box;overflow:hidden;">
    <div style="margin-bottom:14px;text-align:center;user-select:none;flex-shrink:0;">
<div style="font-size:9px;letter-spacing:6px;color:#cc9900;margin-bottom:4px;text-transform:uppercase;text-shadow:0 0 8px #ffe600;">— Aiden Heinz —</div>
      <div style="position:relative;display:inline-block;margin-bottom:2px;">
        <div style="font-size:72px;font-weight:900;letter-spacing:10px;color:#ffe600;font-family:'Courier New',monospace;text-shadow:0 0 40px #ffe600, 0 0 80px #ff8800, 6px 6px 0 #7a4400, 8px 8px 0 #3a2000;line-height:1;">FIGHT</div>
      </div>
      <div style="position:relative;display:inline-block;">
        <div style="font-size:72px;font-weight:900;letter-spacing:10px;color:#ffffff;font-family:'Courier New',monospace;text-shadow:0 0 30px #aaaaff, 6px 6px 0 #444488, 8px 8px 0 #111133;line-height:1;margin-bottom:6px;">DUDES</div>
      </div>
      <div style="width:320px;height:3px;background:linear-gradient(to right,transparent,#ffe600,#ffffff,#ffe600,transparent);margin:8px auto 2px;box-shadow:0 0 12px #ffe600;"></div>
      <div style="font-size:11px;letter-spacing:8px;color:#cc9900;text-shadow:0 0 8px #ffe600;margin-top:4px;text-transform:uppercase;">— Choose Your Fighter —</div>
    </div>

    <!-- Player count -->
   <div style="display:flex;gap:8px;margin-bottom:10px;align-items:center;flex-shrink:0;">
      <span style="font-size:10px;color:#555;letter-spacing:2px;">PLAYERS:</span>
      <button id="btn2p" onclick="setPlayerCount(2)" style="background:#ffe600;color:#000;border:2px solid #ffe600;padding:5px 16px;font-family:'Courier New',monospace;font-size:11px;font-weight:bold;cursor:pointer;letter-spacing:2px;">2P</button>
      <button id="btn3p" onclick="setPlayerCount(3)" style="background:#0a0a14;color:#555;border:2px solid #555;padding:5px 16px;font-family:'Courier New',monospace;font-size:11px;font-weight:bold;cursor:pointer;letter-spacing:2px;">3P</button>
      <button onclick="randomChar(1)" style="background:#0a0a14;color:#4fc3f7;border:2px solid #4fc3f7;padding:5px 10px;font-family:'Courier New',monospace;font-size:10px;cursor:pointer;letter-spacing:1px;">P1 🎲</button>
      <button onclick="randomChar(2)" style="background:#0a0a14;color:#ef5350;border:2px solid #ef5350;padding:5px 10px;font-family:'Courier New',monospace;font-size:10px;cursor:pointer;letter-spacing:1px;">P2 🎲</button>
      <button onclick="randomChar(3)" style="background:#0a0a14;color:#ffe600;border:2px solid #ffe600;padding:5px 10px;font-family:'Courier New',monospace;font-size:10px;cursor:pointer;letter-spacing:1px;">P3 🎲</button>
    </div>

    <!-- Preview row -->
    <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:10px;flex-shrink:0;" id="preview-row">
      <div class="preview-box" id="preview1" style="min-width:160px;">
        <div class="pname" style="color:#4fc3f7">— PLAYER 1 —</div>
        <div class="cname" id="p1name">REX</div>
        <div class="cdesc" id="p1desc">Throws projectiles</div>
        <div class="controls-mini">WASD / Q / E / R</div>
        <div id="p1lock" style="margin-top:5px;font-size:9px;color:#555;">click to select</div>
      </div>
<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 10px;font-size:28px;font-weight:900;color:#ffe600;text-shadow:0 0 20px #ffe600, 0 0 40px #ff8800;font-family:'Courier New',monospace;animation:vspulse 1s infinite alternate;">VS</div>

      <div class="preview-box" id="preview2" style="min-width:160px;text-align:right;">
        <div class="pname" style="color:#ef5350">— PLAYER 2 —</div>
        <div class="cname" id="p2name">GRAMPS</div>
        <div class="cdesc" id="p2desc">Fast gun + dash attack</div>
        <div class="controls-mini">L/' / O / [ / ]</div>
        <div id="p2lock" style="margin-top:5px;font-size:9px;color:#555;text-align:right;">click to select</div>
      </div>
      <div class="preview-box" id="preview3" style="min-width:160px;display:none;">
        <div class="pname" style="color:#ffe600">— PLAYER 3 —</div>
        <div class="cname" id="p3name">ARCHY</div>
        <div class="cdesc" id="p3desc">Bow and Arrow</div>
        <div class="controls-mini">Ctrl+Click to pick</div>
        <div id="p3lock" style="margin-top:5px;font-size:9px;color:#555;">click to select</div>
      </div>
    </div>

    <!-- Char grid — takes remaining space -->
    <div style="background:rgba(0,0,0,0.6);border:3px solid #555;padding:10px 14px 8px;flex:1;min-height:0;overflow-y:auto;width:min(720px,95vw);box-sizing:border-box;">
      <div style="font-size:11px;color:#888;letter-spacing:3px;text-transform:uppercase;margin-bottom:10px;">— Select Character — Click=P1 &nbsp;|&nbsp; Shift=P2 &nbsp;|&nbsp; Ctrl=P3</div>
      <div class="char-grid" id="char-grid" style="display:grid;grid-template-columns:repeat(8,1fr);gap:6px;"></div>
    </div>

    <!-- Lock-in status + next button -->
    <div style="display:flex;align-items:center;gap:12px;margin-top:10px;flex-shrink:0;">
      <div id="lock-status" style="font-size:10px;color:#555;letter-spacing:2px;">Lock in your characters to continue</div>
<button id="botbtn" onclick="toggleBot()" style="background:#0a0a14;color:#555;border:2px solid #555;padding:12px 20px;font-family:'Courier New',monospace;font-size:13px;font-weight:bold;cursor:pointer;letter-spacing:2px;">BOT: OFF</button>
      <button id="botdiffbtn" onclick="cycleBotDiff()" style="background:#0a0a14;color:#555;border:2px solid #555;padding:12px 14px;font-family:'Courier New',monospace;font-size:11px;font-weight:bold;cursor:pointer;letter-spacing:1px;display:none;">EASY</button>
<button id="lockbtn" onclick="lockAndNext()" style="background:linear-gradient(180deg,#2a1a00,#0a0a14);color:#ffe600;border:3px solid #ffe600;padding:12px 36px;font-family:'Courier New',monospace;font-size:15px;font-weight:bold;cursor:pointer;letter-spacing:4px;transition:all 0.1s;box-shadow:0 0 18px #ffe600, inset 0 0 8px rgba(255,230,0,0.1);text-shadow:0 0 8px #ffe600;">LOCK IN ▶</button>
    </div>
  </div>

  <!-- SCREEN 2: MAP SELECT -->
  <div id="screen-maps" style="position:relative;z-index:1;display:none;flex-direction:column;align-items:center;width:100%;height:100vh;padding:18px 0 10px;box-sizing:border-box;overflow:hidden;">
    <div style="margin-bottom:14px;text-align:center;flex-shrink:0;">
      <div style="font-size:28px;font-weight:900;letter-spacing:6px;color:#ffe600;font-family:'Courier New',monospace;text-shadow:3px 3px 0 #111;">SELECT STAGE</div>
      <div style="width:220px;height:2px;background:linear-gradient(to right,transparent,#ffe600,#fff,#ffe600,transparent);margin:6px auto 0;"></div>
    </div>

    <!-- Chosen chars reminder -->
    <div style="display:flex;gap:12px;margin-bottom:14px;flex-shrink:0;" id="map-char-summary"></div>

    <!-- Map grid -->
    <div style="background:rgba(0,0,0,0.6);border:3px solid #555;padding:14px;flex:1;min-height:0;overflow-y:auto;width:min(760px,95vw);box-sizing:border-box;">
      <div style="font-size:11px;color:#888;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;">— Choose Your Battlefield —</div>
      <div id="map-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;"></div>
    </div>

    <!-- Finisher Selection -->
    <div style="width:min(760px,95vw);margin-bottom:10px;box-sizing:border-box;">
      <div style="font-size:11px;color:#888;letter-spacing:3px;text-transform:uppercase;margin-bottom:8px;">— Select Finisher —</div>
      <div id="finisher-row" style="display:flex;gap:10px;flex-wrap:wrap;"></div>
    </div>

    <!-- Options row -->
    <div style="display:flex;flex-direction:column;align-items:center;gap:8px;margin-top:10px;flex-shrink:0;width:min(760px,95vw);">
      <!-- Shards toggle -->
      <div style="display:flex;align-items:center;gap:8px;">
        <div id="shardCheck" onclick="toggleShards()" style="width:16px;height:16px;border:2px solid #444;background:#0a0a14;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:11px;color:#00ff88;flex-shrink:0;transition:all 0.1s;"></div>
        <span style="font-size:10px;color:#555;letter-spacing:2px;cursor:pointer;user-select:none;" onclick="toggleShards()">ENABLE SHARDS ON ANY MAP</span>
      </div>
      <!-- Control schemes -->
      <div id="scheme-row" style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;"></div>
      <!-- Back + Start -->
      <div style="display:flex;gap:12px;margin-top:4px;">
        <button onclick="goBackToChars()" style="background:#0a0a14;color:#888;border:2px solid #555;padding:10px 24px;font-family:'Courier New',monospace;font-size:13px;cursor:pointer;letter-spacing:3px;">◀ BACK</button>
<button id="startbtn" onclick="startGame()" style="background:linear-gradient(180deg,#3a2200,#0a0a14);color:#ffe600;border:3px solid #ffe600;padding:14px 52px;font-family:'Courier New',monospace;font-size:17px;font-weight:bold;cursor:pointer;letter-spacing:6px;box-shadow:0 0 28px #ffe600, 0 0 60px rgba(255,180,0,0.3), inset 0 0 12px rgba(255,230,0,0.08);text-shadow:0 0 10px #ffe600;transition:all 0.15s;animation:vspulse 1.2s infinite alternate;">▶ START ◀</button>
      </div>
    </div>
  </div>
</div>

<div id="ui">
  <div class="p-hud" id="hud1"></div>
  <div style="color:#ffe600; font-size:16px;" id="stock-display"></div>
  <div class="p-hud" id="hud2" style="text-align:right;"></div>
</div>

<div class="p-hud" id="hud3" style="position:fixed;top:8px;left:50%;transform:translateX(-50%);display:none;text-align:center;z-index:5;border-color:#39ff14;"></div>

<canvas id="game"></canvas>

<div id="gameover">
  <div id="trophy-text">🏆</div>
  <h2 id="winner-text">PLAYER 1 WINS!</h2>
  <div id="gameover-chars"></div>
  <button onclick="location.reload()">↩ MAIN MENU</button>
</div>

<script>
  const bgm = document.getElementById("bgm");
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
// ============================================================
// TITLE SCREEN ANIMATED BACKGROUND
// ============================================================
const titleBg = document.getElementById('title-bg');
const tbCtx = titleBg ? titleBg.getContext('2d') : null;
let titleFrame = 0;
const titleStars = Array.from({length:80}, () => ({
  x: Math.random(), y: Math.random(),
  size: Math.random() < 0.15 ? 2 : 1,
  twinkle: Math.random() * Math.PI * 2,
  speed: 0.01 + Math.random() * 0.02
}));
const titleDebris = Array.from({length:18}, () => ({
  x: Math.random(),
  y: Math.random(),
  vy: 0.15 + Math.random() * 0.3,
  vx: (Math.random() - 0.5) * 0.1,
  size: 2 + Math.floor(Math.random() * 4),
  color: ['#ffe600','#ffffff','#e02020','#4fc3f7','#aaaaaa'][Math.floor(Math.random()*5)],
  rot: Math.random() * Math.PI * 2,
  rotSpeed: (Math.random()-0.5)*0.06
}));

function tryPlayBGM() {
  bgm.volume = 0.5;
  const p = bgm.play();
  if(p && p.catch) p.catch(() => {});
}
document.addEventListener('click', tryPlayBGM, { once: true });
document.addEventListener('keydown', tryPlayBGM, { once: true });

function drawTitleBg() {
  if(!tbCtx || !titleBg || document.getElementById('title-screen').style.display === 'none') return;
  titleBg.width = window.innerWidth;
  titleBg.height = window.innerHeight;
  const W = titleBg.width, H = titleBg.height;

  // Deep space bg
  const bg = tbCtx.createRadialGradient(W/2, H*0.5, 0, W/2, H*0.5, W*0.9);
  bg.addColorStop(0, '#1a0a2e');
  bg.addColorStop(0.5, '#0a0a18');
  bg.addColorStop(1, '#000008');
  tbCtx.fillStyle = bg;
  tbCtx.fillRect(0,0,W,H);

  // Star field
  for(const s of titleStars) {
    const twinkle = 0.4 + Math.abs(Math.sin(titleFrame * s.speed + s.twinkle)) * 0.6;
    tbCtx.globalAlpha = twinkle * 0.85;
    tbCtx.fillStyle = '#ffffff';
    tbCtx.fillRect(s.x * W, s.y * H * 0.85, s.size, s.size);
  }
  tbCtx.globalAlpha = 1;

  // Smash-style radial burst lines from center
  const cx = W/2, cy = H*0.38;
  const numRays = 24;
  for(let r=0; r<numRays; r++) {
    const angle = (r/numRays)*Math.PI*2 + titleFrame*0.003;
    const pulse = 0.03 + Math.abs(Math.sin(titleFrame*0.015+r*0.4))*0.04;
    tbCtx.save();
    tbCtx.globalAlpha = pulse;
    tbCtx.strokeStyle = '#ffe600';
    tbCtx.lineWidth = 28;
    tbCtx.beginPath();
    tbCtx.moveTo(cx + Math.cos(angle)*60, cy + Math.sin(angle)*60);
    tbCtx.lineTo(cx + Math.cos(angle)*W, cy + Math.sin(angle)*W);
    tbCtx.stroke();
    tbCtx.restore();
  }

  // Glowing orb behind title
  tbCtx.save();
  const orbPulse = 0.18 + Math.sin(titleFrame*0.025)*0.06;
  const orbG = tbCtx.createRadialGradient(cx, cy, 0, cx, cy, 220);
  orbG.addColorStop(0, `rgba(255,230,0,${orbPulse*2})`);
  orbG.addColorStop(0.3, `rgba(255,180,0,${orbPulse})`);
  orbG.addColorStop(0.7, `rgba(180,60,255,${orbPulse*0.4})`);
  orbG.addColorStop(1, 'transparent');
  tbCtx.fillStyle = orbG;
  tbCtx.beginPath();
  tbCtx.arc(cx, cy, 220, 0, Math.PI*2);
  tbCtx.fill();
  tbCtx.restore();

  // Floating debris
  for(const d of titleDebris) {
    d.y += d.vy * 0.008;
    d.x += d.vx * 0.008;
    d.rot += d.rotSpeed;
    if(d.y > 1) { d.y = -0.05; d.x = Math.random(); }
    tbCtx.save();
    tbCtx.globalAlpha = 0.5;
    tbCtx.translate(d.x * W, d.y * H);
    tbCtx.rotate(d.rot);
    tbCtx.fillStyle = d.color;
    tbCtx.fillRect(-d.size/2, -d.size/2, d.size, d.size);
    tbCtx.restore();
  }

  // Ground shadow line
  const groundY = H * 0.86;
  tbCtx.save();
  tbCtx.globalAlpha = 0.35;
  const groundGrad = tbCtx.createLinearGradient(0, groundY-8, 0, groundY+20);
  groundGrad.addColorStop(0, '#ffe600');
  groundGrad.addColorStop(1, 'transparent');
  tbCtx.fillStyle = groundGrad;
  tbCtx.fillRect(0, groundY-8, W, 28);
