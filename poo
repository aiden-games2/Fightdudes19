function updateBot() {
  if(!botEnabled || !gameRunning) return;
  const bot = players[botPlayerIndex];
  if(!bot || bot.stocks <= 0) return;

  const isEasy = botDifficulty === 'easy';
  // Easy mode: bot acts every other 3 frames and has random hesitation
  if(isEasy && frame % 3 !== 0) return;

  const enemies = players.filter((p, i) => i !== botPlayerIndex && p.stocks > 0);
  if(enemies.length === 0) return;
  const enemy = enemies.reduce((closest, e) =>
    Math.hypot(e.x - bot.x, e.y - bot.y) < Math.hypot(closest.x - bot.x, closest.y - bot.y) ? e : closest
  , enemies[0]);

  const dx = enemy.x - bot.x;
  const dy = enemy.y - bot.y;
  const dist = Math.hypot(dx, dy);
  const absDx = Math.abs(dx);
  const absDy = Math.abs(dy);

  const scheme = bot.controlScheme || 'kb2';
  const keyLeft  = scheme==='kb1'?'KeyA':scheme==='kb2'?'KeyL':'GP2_LEFT';
  const keyRight = scheme==='kb1'?'KeyD':scheme==='kb2'?'Quote':'GP2_RIGHT';
  const keyJump  = scheme==='kb1'?'KeyW':scheme==='kb2'?'KeyP':'GP2_JUMP';
  const keyDown  = scheme==='kb1'?'KeyS':scheme==='kb2'?'Semicolon':'GP2_DOWN';
  const keyAtk   = scheme==='kb1'?'KeyQ':scheme==='kb2'?'KeyO':'GP2_ATTACK';
  const keyAtk2  = scheme==='kb1'?'KeyE':scheme==='kb2'?'BracketLeft':'GP2_SPECIAL';
  const keyR     = scheme==='kb1'?'KeyR':scheme==='kb2'?'BracketRight':'GP2_ABILITY3';

  keys[keyLeft]  = false;
  keys[keyRight] = false;
  keys[keyJump]  = false;
  keys[keyDown]  = false;
  keys[keyAtk]   = false;
  keys[keyAtk2]  = false;
  keys[keyR]     = false;

  const botFrame = frame;
  const attackType = bot.char.attackType;

  // Easy mode cooldowns — bot waits longer between actions
  const attackDelay = isEasy ? 28 : 18;
  const jumpDelay   = isEasy ? 50 : 40;
  const abilityDelay = isEasy ? 300 : 120;
  const reactionChance = isEasy ? 0.75 : 1.0;

  // ---- SURVIVAL LOGIC ----
  const edgeMargin = canvas.width * 0.10;
  const nearLeftEdge  = bot.x < edgeMargin;
  const nearRightEdge = bot.x > canvas.width - edgeMargin;

  if(nearLeftEdge && bot.onGround)  { keys[keyRight] = true; }
  if(nearRightEdge && bot.onGround) { keys[keyLeft]  = true; }

  if(!bot.onGround && bot.y > canvas.height * 0.55 && bot.jumpsLeft > 0) {
    keys[keyJump] = true;
  }
  if(!bot.onGround && bot.y > canvas.height * 0.4) {
    keys[keyJump] = true;
    if(bot.x < canvas.width * 0.2) keys[keyRight] = true;
    if(bot.x > canvas.width * 0.8) keys[keyLeft] = true;
  }

  // ---- DODGE INCOMING PROJECTILES (hard only) ----
  if(!isEasy) {
    const incomingProjectile = projectiles.find(pr => {
      if(pr.owner === bot) return false;
      if(pr.mudWall || pr.firewall || pr.heartBomb) return false;
      const toBot = Math.hypot(pr.x - bot.x, pr.y - bot.y);
      if(toBot > 280) return false;
      const moving = (pr.vx > 0 && pr.x < bot.x) || (pr.vx < 0 && pr.x > bot.x);
      return moving && Math.abs(pr.y - bot.y) < 60;
    });
    if(incomingProjectile && bot.hitStun === 0) {
      if(bot.onGround && botFrame % 8 < 4) keys[keyJump] = true;
      else {
        if(incomingProjectile.vx > 0) keys[keyLeft] = true;
        else keys[keyRight] = true;
      }
    }
  }

  // ---- MOVEMENT TOWARD ENEMY ----
  if(!nearLeftEdge && !nearRightEdge && Math.random() < reactionChance) {
    const isRanged = (attackType === 'projectile' || attackType === 'Arch' || attackType === 'grampy' || attackType === 'goob');
    const preferredDist = isRanged ? (isEasy ? 220 : 260) : (isEasy ? 70 : 90);
    if(absDx > preferredDist + 40) {
      if(dx > 0) keys[keyRight] = true;
      else keys[keyLeft] = true;
    } else if(!isRanged && absDx < 30) {
      // strafe away slightly to avoid getting cornered
      if(dx > 0) keys[keyLeft] = true;
      else keys[keyRight] = true;
    } else {
      if(dx > 0) keys[keyRight] = true;
      else keys[keyLeft] = true;
    }
  }

  // ---- JUMPING TO REACH ENEMY ----
  const enemyHigher = enemy.y < bot.y - 40;
  if(enemyHigher && bot.onGround && absDx < 320 && botFrame % jumpDelay < 5 && Math.random() < reactionChance) {
    keys[keyJump] = true;
    if(enemy.x > bot.x) keys[keyRight] = true;
    else keys[keyLeft] = true;
  }
  if(enemyHigher && !bot.onGround && bot.jumpsLeft > 0 && absDx < 320 && botFrame % 30 < 5) {
    keys[keyJump] = true;
  }
  if(bot.onGround && absDx < 55 && absDy < 30 && botFrame % (jumpDelay + 20) < 5) {
    keys[keyJump] = true;
  }

  // ---- ATTACK LOGIC ----
  const inAttackRange = dist < 170 && absDy < 85;
  const inMeleeRange  = dist < 115 && absDy < 70;
  const canAttack = (bot.attackCooldown || 0) === 0 && bot.hitStun === 0;
  // Easy bot adds artificial delay between attacks
  bot._easyAttackTimer = (bot._easyAttackTimer || 0);
  if(bot._easyAttackTimer > 0) { bot._easyAttackTimer--; }
  const attackAllowed = !isEasy || bot._easyAttackTimer === 0;

  if(canAttack && attackAllowed && Math.random() < reactionChance) {
    if(attackType === 'projectile') {
      if(absDx < 500 && absDy < 80) {
        keys[keyAtk] = true;
        if(isEasy) bot._easyAttackTimer = attackDelay;
      }
    } else if(attackType === 'Arch') {
      if(absDx < 400 && absDy < 70) {
        keys[keyAtk] = true;
        if(isEasy) bot._easyAttackTimer = attackDelay;
      }
    } else if(attackType === 'grampy') {
      if(absDx < 350 && absDy < 60) {
        keys[keyAtk] = true;
        if(isEasy) bot._easyAttackTimer = attackDelay;
      }
    } else if(attackType === 'goob') {
      if(absDx < 420 && absDy < 70) {
        keys[keyAtk] = true;
        if(isEasy) bot._easyAttackTimer = attackDelay;
      }
    } else if(attackType === 'brawler') {
      if(inMeleeRange) {
        keys[keyAtk] = true;
        if(isEasy) bot._easyAttackTimer = attackDelay;
      }
    } else if(attackType === 'ogre') {
      if(absDx > 100 && absDx < 440 && absDy < 80) keys[keyAtk] = true;
      if(inMeleeRange) keys[keyAtk2] = true;
      if(isEasy) bot._easyAttackTimer = attackDelay;
    } else if(attackType === 'tulip') {
      if(absDx < 360 && absDy < 70) {
        keys[keyAtk] = true;
        if(isEasy) bot._easyAttackTimer = attackDelay;
      }
    } else if(attackType === 'icup') {
      if(inMeleeRange) keys[keyAtk] = true;
      else if(absDx < 320 && absDy < 60) keys[keyAtk2] = true;
      if(isEasy) bot._easyAttackTimer = attackDelay;
    }

    // Hard bot uses secondary and abilities more
    if(!isEasy && botFrame % 120 < 8 && inAttackRange) keys[keyAtk2] = true;

    // Ability 3 — hard uses it smart, easy uses it rarely
    const abilityCheck = isEasy ? (botFrame % abilityDelay < 3 && Math.random() < 0.3) : (botFrame % abilityDelay < 3);
    if(abilityCheck) keys[keyR] = true;
  }

  // ---- GROUND SLAM ----
  if(!bot.onGround && bot.vy > 0 && absDx < 60 && bot.y < enemy.y - 20 && Math.random() < reactionChance) {
    keys[keyDown] = true;
  }
}

