function updateMovingPlatforms() {
  if(selectedMap !== 3) return;
  for(const p of PLATFORMS) {
    if(p.static) continue;
    p.phase += 0.008;
    // smooth pause at each end using sine wave
    const raw = Math.sin(p.phase + (p.phaseOffset || 0));
    p.x = p.baseX + raw * p.range;
    // update players standing on this platform
    players.forEach(pl => {
      if(pl.onGround && Math.abs(pl.y - p.y) < 4 && pl.x > p.x && pl.x < p.x + p.w) {
        pl.x += Math.cos(p.phase) * p.range * 0.008;
      }
    });
  }
}

function startGame() {
  document.getElementById('title-screen').style.display = 'none';
  // Scale jump forces and player speed to screen height
  const BASE_HEIGHT = 568;
  const hScale = canvas.height / BASE_HEIGHT;
  CHARS.forEach(ch => {
    ch._baseJumpForce = ch._baseJumpForce || ch.jumpForce;
    ch.jumpForce = Math.round(ch._baseJumpForce * (1 + (Math.sqrt(hScale) - 1) * 0.65));
  });
gameRunning = true;
  if(selectedMap === 3) {
    PLATFORMS = buildAviationPlatforms();
  } else if(selectedMap === 4) {
    PLATFORMS = buildShardCavernPlatforms();
  } else if(selectedMap === 5) {
    PLATFORMS = buildDenOfGodsPlatforms();
  } else {
    PLATFORMS = getMapData()[selectedMap].platforms;
  }
  players = [];
  projectiles = [];
  particles = [];
  frame = 0;if(playerCount >= 3) {
    players.push(new Player(canvas.width*0.20, canvas.height*0.6, p1CharIdx, 1));
    players.push(new Player(canvas.width*0.80, canvas.height*0.6, p2CharIdx, 2));
    players.push(new Player(canvas.width*0.50, canvas.height*0.3, p3CharIdx, 3));
    players[2].dir = -1;
  } else {
    players.push(new Player(canvas.width*0.25, canvas.height*0.6, p1CharIdx, 1));
    players.push(new Player(canvas.width*0.75, canvas.height*0.6, p2CharIdx, 2));
  }
  players.forEach((p, i) => { p.controlScheme = playerSchemes[i] || 'kb1'; });
  if(botEnabled) botPlayerIndex = playerCount - 1; // bot always controls last player
  spawnCrystals();
  updateHUD();
  requestAnimationFrame(gameLoop);
}

let prevDamage = [0, 0, 0];

function updateHUD() {
  const hud3 = document.getElementById('hud3');
  if(hud3) { hud3.style.display = players.length >= 3 ? 'block' : 'none'; hud3.style.borderColor = '#ffe600'; }
  players.forEach((p, i) => {
    const hud = document.getElementById('hud'+(i+1));
    if(!hud) return;
    const dc = p.damage < 60 ? '#ffffff' : p.damage < 120 ? '#ffb300' : '#ff3333';
    const dmgSize = p.damage < 100 ? 32 : p.damage < 150 ? 38 : 44;
    // draw tiny char icon
    const iconCv = document.createElement('canvas');
    iconCv.width = 42; iconCv.height = 42;
    const ictx = iconCv.getContext('2d');
    ictx.scale(0.75, 0.75);
    p.char.draw(ictx, 28, 52, 1, 'idle', false);
    const iconDataURL = iconCv.toDataURL();
    hud.style.borderColor = p.char.color;
    hud.style.borderWidth = '3px';
    hud.style.background = `linear-gradient(135deg, rgba(5,5,20,0.96), rgba(0,0,0,0.92))`;
    hud.style.boxShadow = `0 0 14px ${p.char.color}55, inset 0 0 10px rgba(0,0,0,0.7)`;
    hud.style.padding = '6px 14px 6px 10px';
    hud.style.minWidth = '155px';
    if(Math.floor(p.damage) > (prevDamage[i]||0)) {
      hud.style.background = 'rgba(255,60,60,0.75)';
      setTimeout(()=>{ hud.style.background = `linear-gradient(135deg, rgba(5,5,20,0.96), rgba(0,0,0,0.92))`; }, 220);
      prevDamage[i] = Math.floor(p.damage);
    }
    hud.innerHTML = `
      <div style="display:flex;align-items:center;gap:8px;">
        <img src="${iconDataURL}" width="42" height="42" style="image-rendering:pixelated;border:2px solid ${p.char.color};background:#000;flex-shrink:0;"/>
        <div style="display:flex;flex-direction:column;align-items:${i===1?'flex-end':'flex-start'};">
          <span style="color:${p.char.color};font-size:10px;letter-spacing:2px;font-weight:bold;text-shadow:0 0 6px ${p.char.color};">${p.char.name}</span>
          <span style="color:${dc};font-size:${dmgSize}px;font-weight:900;line-height:1;text-shadow:0 0 12px ${dc}, 2px 2px 0 #000;">${Math.floor(p.damage)}%</span>
        </div>
      </div>`;
  });
  let stocks = '';
  players.forEach((p,i) => {
    if(i>0) stocks += `<span style="color:#444;font-size:11px;padding:0 8px">VS</span>`;
    for(let s=0;s<p.stocks;s++) stocks += `<span style="color:${p.char.color};font-size:22px;text-shadow:0 0 8px ${p.char.color};">♦ </span>`;
  });
  document.getElementById('stock-display').innerHTML = stocks;
}
function gameLoop() {
  if(!gameRunning) return;
  pollGamepads();
  frame++;

  // Check game over
  const alive = players.filter(p => p.stocks > 0);
  if(alive.length <= 1) {
    const winner = alive.length === 1 ? 'PLAYER ' + alive[0].side : 'DRAW';
    document.getElementById('winner-text').textContent = winner + ' WINS!';
    const gChars = document.getElementById('gameover-chars');
    gChars.innerHTML = '';
    players.forEach((p, i) => {
      const wrap = document.createElement('div');
      const isWinner = alive.length === 1 && alive[0] === p;
      wrap.style.cssText = `display:flex;flex-direction:column;align-items:center;gap:6px;opacity:${isWinner?'1':'0.45'};transform:${isWinner?'scale(1.18)':'scale(1)'};transition:all 0.3s;`;
      const cv = document.createElement('canvas');
      cv.width = 80; cv.height = 80;
      const cv2 = cv.getContext('2d');
      cv2.scale(1.4, 1.4);
      p.char.draw(cv2, 28, 54, 1, 'idle', false);
      wrap.appendChild(cv);
      const lbl = document.createElement('div');
      lbl.style.cssText = `font-family:'Courier New',monospace;font-size:11px;color:${isWinner?'#ffe600':'#888'};letter-spacing:2px;`;
      lbl.textContent = (isWinner ? '★ ' : '') + 'P' + p.side + ' — ' + p.char.name;
      wrap.appendChild(lbl);
      if(isWinner) {
        const crown = document.createElement('div');
        crown.style.cssText = 'font-size:28px;margin-bottom:-8px;';
        crown.textContent = '👑';
        wrap.insertBefore(crown, cv);
      }
      gChars.appendChild(wrap);
    });
    document.getElementById('gameover').style.display = 'flex';
    gameRunning = false;
    return;
  }
updateMovingPlatforms();
for(let di = grampsDrones.length-1; di >= 0; di--) {
    const dr = grampsDrones[di];
    dr.life--;
    dr.bobOffset += 0.04;
    dr.x += dr.vx;
    dr.y += Math.sin(dr.bobOffset)*0.6 + dr.vy*0.1;
    dr.vy *= 0.9;
    dr.vx *= 0.88;
    if(Math.abs(dr.vx) > 2.5) dr.vx = 2.5 * Math.sign(dr.vx);
    if(Math.abs(dr.vy) > 1.5) dr.vy = 1.5 * Math.sign(dr.vy);
    const drTarget = players.find(p => p !== dr.owner && p.stocks > 0);
    if(drTarget) {
      const dx = drTarget.x - dr.x;
      const dy = drTarget.y - dr.y;
      const dist = Math.hypot(dx, dy);
      if(dist > 0) { dr.vx += (dx/dist)*0.04; dr.vy += (dy/dist)*0.02; }
    }
   dr.shootTimer--;
    if(dr.shootTimer <= 0 && drTarget) {
      dr.shootTimer = 100 + Math.floor(Math.random() * 120);
      const dx2 = drTarget.x - dr.x;
      const dy2 = drTarget.y - dr.y;
      const dist2 = Math.hypot(dx2, dy2);
      projectiles.push({
        x: dr.x, y: dr.y,
        vx: (dx2/dist2)*14, vy: (dy2/dist2)*14,
        owner: dr.owner, life: 28,
        color: '#93c5fd', big: false, bullet: true, dmg: 2, noGravity: true,
        isDroneBullet: true
      });
      spawnParticles(dr.x, dr.y, '#93c5fd', 4, {type:'line', size:2, life:6, gravity:0, speed:4});
    }
    players.forEach(p => {
      if(p === dr.owner || p.stocks <= 0) return;
      if(Math.abs(p.x - dr.x) < 20 && Math.abs(p.y - dr.y) < 20) {
        dr.hp--;
        p.vx += (p.x - dr.x)*0.1;
        spawnParticles(dr.x, dr.y, '#93c5fd', 6, {type:'star', size:4, life:10, gravity:0, speed:3});
        if(dr.hp <= 0) {
          spawnParticles(dr.x, dr.y, '#93c5fd', 18, {type:'star', size:7, life:20, gravity:0.05, speed:6});
          spawnParticles(dr.x, dr.y, '#ffffff', 10, {type:'line', size:3, life:12, gravity:0, speed:8});
          screenShake = 6;
          grampsDrones.splice(di, 1);
        }
      }
    });
    if(dr.life <= 0 || dr.hp <= 0) {
      if(di < grampsDrones.length) grampsDrones.splice(di, 1);
    }
  }
powerupSpawnTimer++;
  if(powerupSpawnTimer > 1800 && Math.random() < 0.015) {
    trySpawnPowerup();
    powerupSpawnTimer = 0;
  }
  for(let pi = powerups.length - 1; pi >= 0; pi--) {
    const pu = powerups[pi];
    if(pu.collected) { powerups.splice(pi, 1); continue; }
    
    for(const pl of players) {
      if(Math.abs(pl.x - pu.x) < 28 && Math.abs(pl.y - pu.y) < 36) {
          pu.collected = true;
          if(pu.type === 'chalice') {
            pl.chaliceBoost = 600;
            pl.chaliceSpeedBoost = 1.55;
            pl.chaliceJumpBoost = 1.4;
            spawnParticles(pu.x, pu.y, '#d4af37', 22, {type:'star', size:8, life:28, gravity:0, speed:6});
            spawnParticles(pu.x, pu.y, '#ffffff', 12, {type:'circle', size:5, life:20, gravity:0, speed:4});
         } else if(pu.type === 'poison') {
            pl.poisonAttack = 660;
            spawnParticles(pu.x, pu.y, '#76ff03', 22, {type:'star', size:8, life:28, gravity:0, speed:6});
            spawnParticles(pu.x, pu.y, '#ffffff', 12, {type:'circle', size:5, life:20, gravity:0, speed:4});
          } else if(pu.type === 'gluegun') {
            pl.glueGunCharges = 3;
            spawnParticles(pu.x, pu.y, '#00ced1', 22, {type:'star', size:8, life:28, gravity:0, speed:6});
            spawnParticles(pu.x, pu.y, '#ffffff', 12, {type:'circle', size:5, life:20, gravity:0, speed:4});
          }
          screenShake = 10;
          powerupSpawnTimer = 0;
        }
    }
  }
// GOOB: rift2 is static after spawn, just clean up when rift1 dies
  players.forEach(p => {
    if(p.goobRiftX === undefined) {
      p.goobRift2Target = undefined;
      p.goobRift2X = undefined;
      p.goobRift2Hits = 0;
    }
  });

// Den of Gods — rebuild broken platforms
  if(selectedMap === 5) {
    for(const bp of PLATFORMS) {
      if(bp.broken && bp.rebuildTimer > 0) {
        bp.rebuildTimer--;
        if(bp.rebuildTimer === 0) {
          bp.broken = false;
          bp.cracks = 0;
          spawnParticles(bp.x + bp.w/2, bp.y - 6, '#d4af37', 14, {type:'star', size:6, life:22, gravity:-0.04, speed:4});
          spawnParticles(bp.x + bp.w/2, bp.y - 6, '#ffffff', 8, {type:'circle', size:4, life:16, gravity:-0.05, speed:3});
        }
      }
    }
  }

  if(selectedMap === 4 || shardsEnabled) for(const cr of crystals) {
    if(cr.collected) continue;
    cr.bob += 0.05;
    for(const pl of players) {
      if(Math.abs(pl.x - cr.x) < 20 && Math.abs((pl.y - 20) - cr.y) < 20) {
        if((pl.shards || 0) < 3) {
          pl.shards = (pl.shards || 0) + 1;
          cr.collected = true;
          spawnParticles(cr.x, cr.y, '#00ff88', 8, {type:'star', size:5, life:18, gravity:0, speed:3});
          screenShake = 3;
          setTimeout(() => { cr.collected = false; }, 9000);
        }
      }
    }
  }

  // Update
  updateBot();
  players.forEach(p => {
  if((p.burnTimer || 0) > 0) {
    p.burnTimer--;
    if(p.burnTimer % 18 === 0) {
      p.damage += 1;
      spawnParticles(p.x + (Math.random()-0.5)*14, p.y - 20 - Math.random()*20, '#ff4400', 2, {type:'circle', size:4, life:14, gravity:-0.04, speed:1});
    }
  }
});
  players.forEach(p => { p.update(players.find(o => o !== p)); });
  for(let i=0;i<players.length;i++) {
    for(let j=0;j<players.length;j++) {
      if(i===j) continue;
      if(players[j].stocks <= 0) continue;
      players[i].checkHit(players[j]);
    }
  }

