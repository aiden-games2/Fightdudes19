function drawDragonSprite(ctx, x, y, flipX) {
  const ps = 5;
  const cols = 40, rows = 38;
  const totalW = cols * ps;
  const totalH = rows * ps;
  const off = document.createElement('canvas');
  off.width = totalW; off.height = totalH;
  const octx = off.getContext('2d');
  for(let row = 0; row < rows; row++) {
    const rowData = REX_DRAGON_GRID[row];
    if(!rowData) continue;
    for(let col = 0; col < cols; col++) {
      const val = rowData[col];
      if(val === 0 || val === 'BC') continue;
      const cl = PIXEL_COLORS[val];
      if(!cl) continue;
      octx.fillStyle = cl;
      octx.fillRect(col * ps, row * ps, ps, ps);
    }
  }
  ctx.save();
  ctx.translate(Math.round(x), Math.round(y));
  if(flipX) { ctx.scale(-1, 1); ctx.drawImage(off, -totalW / 2, -totalH / 2); }
  else { ctx.drawImage(off, -totalW / 2, -totalH / 2); }
  ctx.restore();
}
