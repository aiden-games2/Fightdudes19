function drawGlueGun(ctx, x, y) {
  const ps = 3;
  const cols = 42;
  const rows = 24;
  for(let row = 0; row < rows; row++) {
    const rowData = GLUE_GUN_GRID[row];
    if(!rowData) continue;
    for(let col = 0; col < cols; col++) {
      const val = rowData[col];
      if(val === 'Y' || val === 0) continue;
      const cl = PIXEL_COLORS[val];
      if(!cl) continue;
      ctx.fillStyle = cl;
      ctx.fillRect(x - (cols*ps/2) + col*ps, y - (rows*ps/2) + row*ps, ps, ps);
    }
  }
}

