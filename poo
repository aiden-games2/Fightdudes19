    ctx.restore();
    if(Math.random() < 0.2) {
      particles.push({ x:r2x+(Math.random()-0.5)*36, y:r2y+(Math.random()-0.5)*56, vx:(Math.random()-0.5)*1.5, vy:-0.8-Math.random(), life:18+Math.random()*12, maxLife:30, color:Math.random()<0.6?'#ff2288':'#ffffff', size:3+Math.random()*3, gravity:-0.01, type:'star', rot:0, rotSpeed:0.1 });
    }
  });

  // IC-UP detached heads
  players.forEach(p => {
    if(!p.icupHeadActive || !p.icupHeadX) return;
    const hx = p.icupHeadX;
    const hy = p.icupHeadY;
    const ps = PIXEL_SIZE;
    ctx.save();
    ctx.translate(Math.round(hx), Math.round(hy));

    // glow pulse
    ctx.globalAlpha = 0.4 + Math.sin(frame*0.2)*0.15;
    const hg = ctx.createRadialGradient(0,0,0,0,0,26);
    hg.addColorStop(0,'#ffe033'); hg.addColorStop(1,'transparent');
    ctx.fillStyle = hg;
    ctx.beginPath(); ctx.arc(0,0,26,0,Math.PI*2); ctx.fill();
    ctx.globalAlpha = 1;

    // full head pixel art matching your design (rows 0-6 of the main grid)
    // centered so row 6 (mouth/bottom) lands at y=0 (the head's feet)
    const headGrid = [
      [0,0,0,0,'E', 0 ,0,0,0,'E',0,0,0,0],   // row 0 antennae
      [0,0,0,0,'C','C','C','C','C','C',0,0,0,0], // row 1 stalk
      [0,0,0,'C','C', 1, 1 , 1 , 1 ,'C','C',0,0,0], // row 2 top
      [0,0,0,'C', 1 ,1 ,'I', 14 , 1 ,1,'C',0,0,0], // row 3 eyes top
      [0,0,0,'C', 1 , 1 ,'I','I', 1 ,1,'C', 0,0,0], // row 4 eyes
      [0,0,0,'C','C',1,1,1,1,'C','C',0,0,0], // row 5 chin
      [0,0,0,0,'C','C','C','C','C','C',0,0,0,0], // row 6 mouth/base
    ];
    const headRows = headGrid.length; // 7
    const headCols = 14;
    // draw so that row 6 is at y=0, meaning row 0 is at y = -6*ps
    for(let row = 0; row < headRows; row++) {
      const rowData = headGrid[row];
      for(let col = 0; col < headCols; col++) {
        const val = rowData[col];
        if(val === 0) continue;
        const cl = PIXEL_COLORS[val];
        if(!cl) continue;
        ctx.fillStyle = cl;
        // center horizontally: col 0 starts at -7*ps
        ctx.fillRect((col - 7) * ps, (row - headRows + 1) * ps, ps, ps);
      }
    }

    // timer bar above head
    const ratio = p.icupHeadTimer / 300;
    ctx.fillStyle = '#111111';
    ctx.fillRect(-20, -headRows*ps - 6, 40, 4);
    ctx.fillStyle = ratio > 0.4 ? '#ffe033' : '#ff4400';
    ctx.fillRect(-20, -headRows*ps - 6, 40 * ratio, 4);

    ctx.restore();
  });
  for(const pu of powerups) {
    if(pu.collected) continue;
    pu.bob += 0.04;
    const puY = pu.y + Math.sin(pu.bob) * 5;
    ctx.save();
    ctx.globalAlpha = 1;
    if(pu.type === 'chalice') {
      const ps = 2;
      const cols = 17;
      const rows = 30;
      for(let row = 0; row < rows; row++) {
        const rowData = CHALICE_GRID[row];
        if(!rowData) continue;
        for(let col = 0; col < cols; col++) {
          const val = rowData[col];
          if(val === '0' || val === 0) continue;
          const cl = PIXEL_COLORS[val];
          if(!cl) continue;
          ctx.fillStyle = cl;
          ctx.fillRect(Math.round(pu.x - (cols * ps / 2) + col * ps), Math.round(puY - (rows * ps / 2) + row * ps), ps, ps);
        }
      }
      ctx.fillStyle = '#d4af37';
      ctx.font = 'bold 11px Courier New';
      ctx.textAlign = 'center';
      ctx.fillText('CHALICE', pu.x, puY - (rows * 3 / 2) - 6);
    } else if(pu.type === 'poison') {
      const ps = 3;
      const cols = 31;
      const rows = 32;
      for(let row = 0; row < rows; row++) {
        const rowData = POISON_GRID[row];
        if(!rowData) continue;
        for(let col = 0; col < cols; col++) {
          const val = rowData[col];
          if(val === '0' || val === 0) continue;
          const cl = PIXEL_COLORS[val];
          if(!cl) continue;
          ctx.fillStyle = cl;
          ctx.fillRect(Math.round(pu.x - (cols * ps / 2) + col * ps), Math.round(puY - (rows * ps / 2) + row * ps), ps, ps);
        }
      }
      ctx.fillStyle = '#76ff03';
      ctx.font = 'bold 11px Courier New';
      ctx.textAlign = 'center';
      ctx.fillText('POISON', pu.x, puY - (rows * 3 / 2) - 6);
    } else if(pu.type === 'gluegun') {
      drawGlueGun(ctx, pu.x, puY);
      ctx.fillStyle = '#00ced1';
      ctx.font = 'bold 11px Courier New';
      ctx.textAlign = 'center';
      ctx.fillText('GLUE GUN', pu.x, puY - 42);
    }
    ctx.restore();
  }
  for(const dr of grampsDrones) {
    ctx.save();
    const ps = 4;
    const dcols = 31;
    const drows = 16;
    for(let row = 0; row < drows; row++) {
      const rowData = DRONE_GRID[row];
      if(!rowData) continue;
      for(let col = 0; col < dcols; col++) {
        const val = rowData[col];
        if(val === '0' || val === 0) continue;
        const cl = PIXEL_COLORS[val];
        if(!cl) continue;
        ctx.fillStyle = cl;
        ctx.fillRect(Math.round(dr.x - (dcols*ps/2) + col*ps), Math.round(dr.y - (drows*ps/2) + row*ps), ps, ps);
      }
    }
    const hpW = 36;
    ctx.fillStyle = '#1a1a1a';
    ctx.fillRect(dr.x - hpW/2, dr.y - drows*ps/2 - 10, hpW, 5);
    ctx.fillStyle = dr.hp >= 2 ? '#39ff14' : '#ff4400';
    ctx.fillRect(dr.x - hpW/2, dr.y - drows*ps/2 - 10, hpW*(dr.hp/dr.maxHp), 5);
    ctx.fillStyle = '#93c5fd';
    ctx.font = 'bold 8px Courier New';
    ctx.textAlign = 'center';
    ctx.fillText('DRONE', dr.x, dr.y - drows*ps/2 - 13);
    if(Math.random() < 0.3) {
      particles.push({
        x: dr.x+(Math.random()-0.5)*8,
        y: dr.y + drows*ps/2 - 4,
        vx: (Math.random()-0.5)*1.2,
        vy: 1+Math.random()*2,
        life: 12+Math.random()*8, maxLife: 20,
        color: Math.random()<0.5?'#93c5fd':'#ffffff',
        size: 3+Math.random()*3, gravity: 0.03,
        type: 'circle', rot:0, rotSpeed:0
      });
    }
    ctx.restore();
  }

  // Players
  players.forEach(p => p.draw());
  players.forEach(p => {
    if((p.archHoming||0) > 0 && p.archTarget) {
      const t = p.archTarget;
      const pulse = 0.5 + Math.sin(frame*0.2)*0.5;
      ctx.save();
      ctx.globalAlpha = pulse;
      ctx.strokeStyle = '#39ff14';
      ctx.lineWidth = 3;
      ctx.beginPath(); ctx.arc(t.x, t.y-30, 30, 0, Math.PI*2); ctx.stroke();
      ctx.lineWidth = 2;
      ctx.beginPath(); ctx.moveTo(t.x-48,t.y-30); ctx.lineTo(t.x-32,t.y-30); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(t.x+32,t.y-30); ctx.lineTo(t.x+48,t.y-30); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(t.x,t.y-78); ctx.lineTo(t.x,t.y-62); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(t.x,t.y+2); ctx.lineTo(t.x,t.y+18); ctx.stroke();
      ctx.fillStyle = '#39ff14';
      ctx.font = 'bold 9px Courier New';
      ctx.textAlign = 'center';
      ctx.fillText('🎯 LOCKED', t.x, t.y-82);
      ctx.restore();
    }
  });
  // ---- GRENADE EXPLOSION SPRITES ----
  for(let gi = grenadeExplosions.length-1; gi >= 0; gi--) {
    const ge = grenadeExplosions[gi];
    ge.timer--;
    if(ge.timer <= 0) { grenadeExplosions.splice(gi,1); continue; }
    const gRatio = ge.timer / ge.maxTimer;
    const geRows = GRENADE_EXPLOSION_GRID.length;
    const geCols = GRENADE_EXPLOSION_GRID[0].length;
    const geps = 4 + Math.round((1-gRatio)*3);
    const geW = geCols * geps;
    const geH = geRows * geps;
    const geOff = getFinisherCanvas('grenade_exp', () => {
      const c = document.createElement('canvas');
      c.width = geCols*3; c.height = geRows*3;
      const cx2 = c.getContext('2d');
      cx2.imageSmoothingEnabled = false;
      for(let row=0;row<geRows;row++){
        const rd=GRENADE_EXPLOSION_GRID[row]; if(!rd) continue;
        for(let col=0;col<geCols;col++){
          const val=rd[col];
          if(val==='AX'||val===0) continue;
          const cl=PIXEL_COLORS[val]; if(!cl) continue;
          cx2.fillStyle=cl;
          cx2.fillRect(col*3,row*3,3,3);
        }
      }
      return c;
    });
    const geScale = (95 * 2) / geOff.width;
    const geDrawW = geOff.width * geScale;
    const geDrawH = geOff.height * geScale;
    ctx.save();
    ctx.globalAlpha = gRatio * 0.92;
    ctx.drawImage(geOff, ge.x - geDrawW/2, ge.y - geDrawH, geDrawW, geDrawH);
    ctx.restore();
  }
  // ---- DRAW FINISHER OVERLAY ----
  if (finisherState) {
    finisherState.timer--;
    const t = finisherState.timer;
    const mt = finisherState.maxTimer;
    const ratio = t / mt;
    const cx2 = finisherState.x, cy2 = finisherState.y;
    ctx.save();

    if (finisherState.type === 'default') {
      if (t > mt * 0.78) {
        const flashAlpha = ((t - mt*0.78) / (mt*0.22)) * 0.72;
        const flashR = (1 - (t-mt*0.78)/(mt*0.22)) * canvas.width * 1.2;
        ctx.globalAlpha = flashAlpha;
        ctx.fillStyle = '#ffffff';
        ctx.beginPath(); ctx.arc(cx2, cy2, flashR, 0, Math.PI*2); ctx.fill();
      }
      if (t < mt*0.82 && t > mt*0.08) {
        const scale = 1 + (1-ratio)*0.25;
        ctx.globalAlpha = Math.min(1, t < mt*0.15 ? t/(mt*0.15) : 1);
        ctx.save();
        ctx.translate(canvas.width/2, canvas.height/2 - 30);
        ctx.scale(scale, scale);
        ctx.fillStyle = '#ffe600';
        ctx.font = 'bold 90px Courier New';
        ctx.textAlign = 'center';
        ctx.shadowColor = '#ff8800'; ctx.shadowBlur = 40;
        ctx.fillText('K.O.!', 0, 0);
        ctx.shadowColor = '#ffffff'; ctx.shadowBlur = 80;
        ctx.fillText('K.O.!', 0, 0);
        ctx.restore();
      }
    }

    else if (finisherState.type === 'mystbloom') {
      if (t > mt * 0.74) {
        const bloomAlpha = ((t - mt*0.74)/(mt*0.26)) * 0.6;
        ctx.globalAlpha = bloomAlpha;
        const bg2 = ctx.createRadialGradient(cx2, cy2, 0, cx2, cy2, canvas.width);
        bg2.addColorStop(0, '#ff69b4');
        bg2.addColorStop(0.45, 'rgba(255,160,210,0.35)');
        bg2.addColorStop(1, 'transparent');
        ctx.fillStyle = bg2;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      }
      // Sparkle burst grid behind flower
      if (t < mt*0.82 && t > mt*0.08) {
        const spRows = MYSTBLOOM_SPARKLE_GRID.length;
        const spCols = MYSTBLOOM_SPARKLE_GRID[0].length;
        const spps = 10;
        const spW = spCols * spps;
        const spH = spRows * spps;
        const spOff = getFinisherCanvas('sparkle_'+spps, () => {
          const c = document.createElement('canvas');
          c.width = spW; c.height = spH;
          const cx2 = c.getContext('2d');
          cx2.imageSmoothingEnabled = false;
          for(let row=0;row<spRows;row++){
            const rd=MYSTBLOOM_SPARKLE_GRID[row]; if(!rd) continue;
            for(let col=0;col<spCols;col++){
              const val=rd[col];
              if(val==='AX'||val===0) continue;
              cx2.fillStyle = val==='G' ? '#ffaad4' : '#ffffff';
              cx2.fillRect(col*spps,row*spps,spps,spps);
            }
          }
          return c;
        });
        const spAlpha = Math.min(0.55, (t > mt*0.72 ? (mt*0.82-t)/(mt*0.1) : 1) * (t < mt*0.18 ? t/(mt*0.1) : 1) * 0.55);
        ctx.save();
        ctx.globalAlpha = spAlpha;
        ctx.drawImage(spOff, canvas.width/2 - spW/2, canvas.height/2 - spH/2);
        ctx.restore();
      }
      // Draw flower sprite centered on screen
      if (t < mt*0.65 && t > mt*0.18) {
        const flRows = MYSTBLOOM_FLOWER_GRID.length;
        const flCols = MYSTBLOOM_FLOWER_GRID[0].length;
        const fps = 7;
        const flW = flCols * fps;
        const flH = flRows * fps;
        const flStartX = Math.round(canvas.width/2 - flW/2);
        const flStartY = Math.round(canvas.height/2 - flH/2);
        const flOff = getFinisherCanvas('flower_'+fps, () => {
          const c = document.createElement('canvas');
          c.width = flW; c.height = flH;
          const cx2 = c.getContext('2d');
          cx2.imageSmoothingEnabled = false;
          for(let row=0;row<flRows;row++){
            const rd=MYSTBLOOM_FLOWER_GRID[row]; if(!rd) continue;
            for(let col=0;col<flCols;col++){
              const val=rd[col];
              if(val==='AX'||val===0) continue;
              const cl=PIXEL_COLORS[val]; if(!cl) continue;
              cx2.fillStyle=cl;
              cx2.fillRect(col*fps,row*fps,fps,fps);
            }
          }
          return c;
        });
        const fadeIn  = t > mt*0.58 ? (mt*0.65-t)/(mt*0.07) : 1;
        const fadeOut = t < mt*0.25 ? t/(mt*0.07) : 1;
        ctx.globalAlpha = Math.min(fadeIn, fadeOut);
        ctx.drawImage(flOff, flStartX, flStartY);
      }
      if (t < mt*0.82 && t > mt*0.08) {
        const scale = 1 + (1-ratio)*0.22;
        ctx.globalAlpha = Math.min(1, t < mt*0.15 ? t/(mt*0.15) : 1);
        ctx.save();
        ctx.translate(canvas.width/2, canvas.height/2 - 25);
        ctx.scale(scale, scale);
        ctx.fillStyle = '#ff69b4';
        ctx.font = 'bold 74px Courier New';
        ctx.textAlign = 'center';
        ctx.shadowColor = '#ff1493'; ctx.shadowBlur = 40;
        ctx.fillText('K.O.!', 0, 0);
        ctx.shadowColor = '#ffffff'; ctx.shadowBlur = 60;
        ctx.fillText('K.O.!', 0, 0);
        ctx.restore();
      }
    }

    ctx.restore();
    if (finisherState.timer <= 0) finisherState = null;
  }

  requestAnimationFrame(gameLoop); // update?
}
</script>
</body>
