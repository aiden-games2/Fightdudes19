      rot: Math.random()*Math.PI, rotSpeed:(Math.random()-0.5)*0.45
    });
  }
  // speed lines shooting in hit direction
  for(let i=0;i<8;i++) {
    particles.push({
      x, y,
      vx: dir*(9+Math.random()*12),
      vy: (Math.random()-0.5)*4,
      life: 10+Math.random()*6, maxLife: 16,
      color: i%2===0?'#ffffff':color,
      size: 2+Math.random()*3,
      gravity: 0, type: 'line', rot:0, rotSpeed:0
    });
