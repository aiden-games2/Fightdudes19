      const val = rowData[col];
      if(val === '0' || val === 0) continue;
      const cl = PIXEL_COLORS[val];
      if(!cl) continue;
      ctx.fillStyle = cl;
      ctx.fillRect(x - (cols * ps / 2) + col * ps, y - (rows * ps / 2) + row * ps, ps, ps);
    }
  }
}

function drawChalice(ctx, x, y) {
  const ps = 3;
  const cols = 17;
  const rows = 30;
  for(let row = 0; row < rows; row++) {
    const rowData = CHALICE_GRID[row];
    if(!rowData) continue;
    for(let col = 0; col < cols; col++) {
      const val = rowData[col];
      if(val === '0' || val === 0) continue;
      const cl = PIXEL_COLORS[val];
      if(!cl) continue;
      ctx.fillStyle = cl;
      ctx.fillRect(x - (cols * ps / 2) + col * ps, y - (rows * ps / 2) + row * ps, ps, ps);
    }
  }
}

function spawnCrystals() {
  crystals = [];
  for(const p of PLATFORMS) {
    const slots = Math.max(1, Math.floor(p.w / 140));
    for(let s = 0; s < slots; s++) {
      if(Math.random() < 0.4) {
        crystals.push({
          x: p.x + p.w * ((s + 0.25 + Math.random() * 0.5) / slots),
          y: p.y - 18,
          bob: Math.random() * Math.PI * 2,
          collected: false
        });
      }
    }
  }
}

function spawnParticles(x, y, color, count, opts={}) {
  if(particles.length > 280) return;
  for(let i=0;i<count;i++) {
    const angle = opts.spread ? (Math.random()-0.5)*opts.spread : Math.PI*2*Math.random();
    const spd = opts.speed ? opts.speed*(0.5+Math.random()*0.8) : (3+Math.random()*4);
    particles.push({
      x, y,
      vx: Math.cos(angle)*spd,
      vy: Math.sin(angle)*spd - (opts.upward ? 2 : 0),
      life: (opts.life || 30) + Math.random()*20,
      maxLife: (opts.life || 30) + 20,
      color: opts.colors ? opts.colors[Math.floor(Math.random()*opts.colors.length)] : color,
      size: opts.size ? opts.size*(0.6+Math.random()*0.8) : (3+Math.random()*4),
      gravity: opts.gravity !== undefined ? opts.gravity : 0.15,
      type: opts.type || 'square',
      rot: Math.random()*Math.PI*2,
      rotSpeed: (Math.random()-0.5)*0.3
    });
  }
}

function spawnLandingDust(x, y) {
  for(let i=0;i<7;i++) {
    const side = i%2===0?1:-1;
    particles.push({
      x: x + side*(4+i*3), y,
      vx: side*(1+Math.random()*2.5),
      vy: -1 - Math.random()*1.5,
      life: 18+Math.random()*10, maxLife: 28,
      color: '#8888aa', size: 5+Math.random()*5,
      gravity: 0.05, type: 'circle', rot:0, rotSpeed:0
    });
  }
}

function spawnHitSparks(x, y, dir, color) {
  // big ring burst
  for(let i=0;i<18;i++) {
    const angle = (i/18)*Math.PI*2;
    const spd = 5+Math.random()*7;
