function pollGamepads() {
  const pads = navigator.getGamepads();
  // P1 = first controller, P2 = second controller
  for(let gi = 0; gi < 3; gi++) {
    const pad = pads[gi];
    if(!pad) continue;
    const prefix = `GP${gi+1}_`;
    // Left stick / D-pad for movement
    const lx = pad.axes[0];
    const ly = pad.axes[1];
    keys[prefix+'LEFT']  = lx < -0.3 || pad.buttons[14]?.pressed;
    keys[prefix+'RIGHT'] = lx >  0.3 || pad.buttons[15]?.pressed;
    keys[prefix+'UP']    = ly < -0.3 || pad.buttons[12]?.pressed;
    keys[prefix+'DOWN']  = ly >  0.3 || pad.buttons[13]?.pressed;
    // A = jump, X = attack, B = special, Y = special2
    keys[prefix+'JUMP']    = pad.buttons[0]?.pressed;  // A
    keys[prefix+'ATTACK']  = pad.buttons[2]?.pressed;  // X
    keys[prefix+'SPECIAL'] = pad.buttons[1]?.pressed;  // B
    keys[prefix+'SHARD']   = pad.buttons[5]?.pressed;  // RB
    keys[prefix+'ABILITY3']= pad.buttons[3]?.pressed;  // Y
  }
}

